# Copy this file to .env and fill in your values.
# On a VPS, export these variables before running main.py,
# or use a process manager (systemd, supervisor, pm2) to inject them.

# ── Required ──────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Google Sheet ID (the long ID in the Sheets URL)
SHEET_ID=your_google_sheet_id_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Port for the Flask keep-alive status server (default: 5000)
# FLASK_PORT=5000

# ── VPS setup notes ───────────────────────────────────────────────────────────
# 1. Place service_account.json in the same directory as main.py
#    (it is gitignored and must be copied to the server manually)
# 2. Install dependencies:  pip install -r requirements.txt
# 3. Run the bot:           python3 main.py
#    Or with systemd/supervisor to keep it alive automatically.
