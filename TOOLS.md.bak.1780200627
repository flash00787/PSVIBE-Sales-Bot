**Usage Examples:**
```bash
# ── Core Dev Tools ──

# State machine audit (NOTE: use --analyze, NOT --full)
python3 /root/coordination/flow_analyzer.py --analyze --states --report --check-await

# Circular dependency check
python3 /root/coordination/arch_mapper.py --circular --dep-text

# Code quality audit (--full IS valid here)
python3 /root/coordination/enhanced_validator.py --full

# Run single tool pipeline
python3 /root/coordination/tool_orchestrator.py 2>&1 | tail -20

# Quality Gate (quick mode)
python3 /root/coordination/quality_gate.py --quick

# ── Workflow Engine ──

# Check status / recent runs
python3 /root/coordination/workflow_engine.py --status

# Run pipeline
python3 /root/coordination/workflow_engine.py --run quality
python3 /root/coordination/workflow_engine.py --run full-audit
python3 /root/coordination/workflow_engine.py --run safe-fix
python3 /root/coordination/workflow_engine.py --run auto-deploy

# Retry last failed pipeline
python3 /root/coordination/workflow_engine.py --retry

# View history with timestamps
python3 /root/coordination/workflow_engine.py --history

# ── Task Bridge (Sub-agent Integration) ──

# Create a sub-agent task
python3 /root/coordination/task_bridge.py create --pipeline safe-fix --step "Fix imports" --files handlers/admin.py

# Check pending tasks
python3 /root/coordination/task_bridge.py list pending

# Mark task complete (done by sub-agent)
python3 /root/coordination/task_bridge.py complete <task-id> --status ok --message "Fixed"

# ── Notifier ──

# Send notification
python3 /root/coordination/notifier.py send --title "Pipeline done" --message "4/4 ✅" --level success

# List unread notifications (Kora heartbeat checks this)
python3 /root/coordination/notifier.py list --unread

# ── Hybrid Batch System (NEW — 2026-05-30) ──

# Estimate: Sequential vs Hybrid time comparison
python3 /root/coordination/batch_coordinator.py --estimate bot/handlers/admin.py bot/handlers/sales.py

# Auto-Split: Auto-detect dependencies, split into parallel batches
python3 /root/coordination/batch_coordinator.py --auto-split bot/handlers/admin.py bot/handlers/sales.py bot/handlers/console_mgmt.py

# Plan: Manual dependency analysis
python3 /root/coordination/batch_coordinator.py --plan

# Dispatch with priority
python3 /root/coordination/batch_coordinator.py --dispatch batches.json --priority high

# Status: Check active locks + batch progress
python3 /root/coordination/batch_coordinator.py --status

# Merge: Collect results from all parallel agents
python3 /root/coordination/batch_coordinator.py --merge

# Smart Retry: Auto-analyze failure type → re-dispatch
python3 /root/coordination/batch_coordinator.py --retry 2

# Rollback: Per-batch rollback if one fails
python3 /root/coordination/batch_coordinator.py --rollback

# Estimate log: Track actual vs estimated
python3 /root/coordination/batch_coordinator.py --estimate-log --batch-id 1 --actual 12

# Cross-bot batching
python3 /root/coordination/batch_coordinator.py --remote --bots "sale-bot,customer-bot,api-server"

# ── Queue Manager ──

# Enqueue task
python3 /root/coordination/queue_manager.py --enqueue --task "fix sales.py" --priority high

# List queued tasks
python3 /root/coordination/queue_manager.py --list

# Dequeue (auto-dispatch when slots free)
python3 /root/coordination/queue_manager.py --dequeue

# Check dead-letter queue
python3 /root/coordination/queue_manager.py --dead-letter

# ── Verify Agent (Hybrid mode) ──

# Quick partial verify (during parallel batch)
python3 /root/coordination/verify_agent.py verify --files "bot/handlers/admin.py" --partial

# Full verify (all 33 tests)
python3 /root/coordination/verify_agent.py verify --full

# Merge conflict check (before parallel dispatch)
python3 /root/coordination/verify_agent.py merge-check --files "admin.py" "console_mgmt.py"

# ── Notifier (Hybrid mode) ──

# Send batch notification
python3 /root/coordination/notifier.py send-batch --batch-id 1 --total 3 --results "admin:OK,sales:OK"

# Check batch status
python3 /root/coordination/notifier.py batch-status --batch-id 1

# View all batch history
python3 /root/coordination/notifier.py batch-summary

# ── Fix Protocol (MANDATORY before ANY code fix) ──

# START: pre-fix checks + lock + snapshot (supports per-file lock now)
python3 /root/coordination/fix_protocol.py --start bot/handlers/admin.py    # different files = parallel OK
python3 /root/coordination/fix_protocol.py --start bot/handlers/sales.py     # ← runs in parallel with above

# COMPLETE: verify + diff check + auto-commit + release lock
python3 /root/coordination/fix_protocol.py --complete

# On failure: rollback
python3 /root/coordination/fix_protocol.py --complete --rollback

# ── Auto Healer ──

# Check and heal if needed
python3 /root/coordination/auto_healer.py check

# View status
python3 /root/coordination/auto_healer.py status

# View heal history
python3 /root/coordination/auto_healer.py history

# ── Other ──

# Safe fix workflow (NOTE: --target-file required, NOT --directory)
python3 /root/coordination/fix_safety.py snapshot --target-file bot/handlers/main_menu.py
python3 /root/coordination/fix_safety.py verify --target-file bot/handlers/main_menu.py

# Health dashboard
python3 /root/coordination/health_dashboard.py

# ── Batch Dashboard (NEW — 2026-05-30) ──

# Start dashboard server (port 9090)
python3 /root/coordination/dashboard.py --port 9090

# Start with custom history file path
python3 /root/coordination/dashboard.py --port 9090 --history /tmp/batch_history.json

# The server serves:
#   /              → dashboard.html (self-contained dark-themed UI)
#   /api/status    → batch_history.json
#   /api/estimate  → estimate_history.json
#   /api/queue     → task_queue.json
#   /api/health    → health check
# 
# Dashboard features:
#   - Batch history table with hover file tooltips
#   - Stats cards (total/success/recovered/failed)
#   - Real-time queue status (auto-refresh every 10s)
#   - Estimate accuracy chart (CSS bars, no JS libs)
#   - Dark theme (PS VIBE: black/cyan/magenta)
#
# Can run via screen/tmux or systemd
# Not required for normal operation

# Kill dashboard server
pkill -f "dashboard.py.*9090"
```


