# ============================================
# iBet789 Telegram Bot — Environment Config
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# Telegram Bot Token from @BotFather (REQUIRED)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# iBet789 Agent Login Credentials
AGENT_USERNAME=
AGENT_PASSWORD=

# iBet789 Agent Dashboard URL
# Common domains:
#   https://ibet789agent.com/
#   https://agent.ibet789.com/
#   https://www.ibet789agent.com/
#   https://ibet789agent.net/
AGENT_URL=https://ibet789agent.com/

# Telegram User IDs allowed to use the bot (comma-separated)
# Get your ID from @userinfobot on Telegram
ALLOWED_USERS=6296803251

# Puppeteer headless mode (true = no GUI, false = show browser window)
PUPPETEER_HEADLESS=true

# Session timeout in minutes (auto re-login after this)
SESSION_TIMEOUT_MIN=15

# ──────────────────────────────────────────
