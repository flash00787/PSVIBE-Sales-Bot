# PS VIBE — Environment Configuration
# Copy to .env and fill in secrets.
# Secrets (tokens, keys, passwords) live in /etc/psvibe/secrets.env

# === MySQL Database ===
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=psvibe_user
MYSQL_PASSWORD=<set_in_secrets>
MYSQL_DATABASE=psvibe_api

# === API ===
API_KEY=<set_in_secrets>
API_BASE_URL=http://localhost:8000
RECEIPT_BASE_URL=https://ps-vibe.com
RECEIPT_SECRET=<set_in_secrets>

# === Telegram Bots ===
BOT_TOKEN=<set_in_secrets>
CUSTOMER_BOT_TOKEN=<set_in_secrets>
TELEGRAM_BOT_TOKEN=<set_in_secrets>  # Wallet bot

# === Google Sheets ===
SHEET_ID=1VFNvhdcYVlVrr5TS49n2peIZa3U6y_AI-Mfo7q7gVsA
ANALYTICS_SHEET_ID=1fh9Rga-XU2971BxdcAnboaFQuJfcT-c1xDfUVNrIuPE
WALLET_SHEET_ID=1mlc9AmhwIVCk7egJoQgX4ld6z9kpwciDegxYA8_BPRc

# === AI / External APIs ===
GEMINI_API_KEY=<set_in_secrets>
OPENROUTER_API_KEY=<set_in_secrets>

# === Bot Config ===
STAFF_NOTIFY_CHAT=-1003686032747
BOT_TIMEZONE=Asia/Yangon
ALLOWED_USER_IDS=6296803251
TELEGRAM_CHAT_ID=6296803251
PORT=3000
LOW_BALANCE_THRESHOLD=120
STOCK_PIN=<set_in_secrets>
SYNC_INTERVAL=300

# === Webhooks ===
N8N_SESSION_WEBHOOK=https://ps-vibe.com/webhook/session-reminder
N8N_BOOKING_WEBHOOK=https://ps-vibe.com/webhook/booking-reminder

